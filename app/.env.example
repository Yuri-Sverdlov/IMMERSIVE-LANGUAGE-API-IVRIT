# --- Gemini Developer API (наш режим, НЕ Vertex) ---
# Получить ключ: https://aistudio.google.com -> Get API key
GEMINI_API_KEY=your-gemini-api-key
# Live-модель developer-API
MODEL=gemini-3.1-flash-live-preview
# Режим разработки (true отключает Redis/reCAPTCHA для локального запуска)
DEV_MODE=true

# --- Vertex AI (НЕ используется в этом режиме; оставлено для совместимости) ---
# Если захочешь вернуться на Vertex: задай PROJECT_ID/LOCATION, убери GEMINI_API_KEY,
# верни MODEL=gemini-live-2.5-flash-native-audio и выполни gcloud auth application-default login.
PROJECT_ID=your-project-id
LOCATION=us-central1
