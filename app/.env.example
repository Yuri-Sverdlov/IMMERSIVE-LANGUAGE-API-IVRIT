# --- Gemini Developer API (our mode, NOT Vertex) ---
# IMPORTANT: keep this file ASCII-only. starlette reads .env as cp1252 on Windows;
# non-ASCII characters (e.g. Cyrillic) cause UnicodeDecodeError at startup.
# Get a key: https://aistudio.google.com -> Get API key
GEMINI_API_KEY=your-gemini-api-key
# Developer-API live model
MODEL=gemini-3.1-flash-live-preview
# Dev mode (true disables Redis/reCAPTCHA for local run)
DEV_MODE=true
# Session time limit in seconds (420 = 7 minutes)
SESSION_TIME_LIMIT=420

# --- Vertex AI (NOT used in this mode; kept for compatibility) ---
# To switch back to Vertex: set PROJECT_ID/LOCATION, remove GEMINI_API_KEY,
# set MODEL=gemini-live-2.5-flash-native-audio, run gcloud auth application-default login.
PROJECT_ID=your-project-id
LOCATION=us-central1
